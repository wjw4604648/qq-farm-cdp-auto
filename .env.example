# Copy this file to .env or .env.local and adjust as needed.

# Runtime target: cdp | qq_ws | auto
FARM_RUNTIME_TARGET=qq_ws

# Gateway（FARM_QQ_HOST_WS_URL 的端口须与本端口一致）
FARM_GATEWAY_HOST=127.0.0.1
FARM_GATEWAY_PORT=8787
FARM_QQ_WS_PATH=/miniapp
FARM_QQ_WS_READY_TIMEOUT_MS=15000
FARM_QQ_WS_CALL_TIMEOUT_MS=15000

# QQ patch / host
# FARM_QQ_GAME_JS=D:\\path\\to\\qq-miniapp\\game.js
# FARM_QQ_APPID=1112386029
# FARM_QQ_MINIAPP_SRC_ROOT 留空则自动扫描 %APPDATA%\QQ 和 %APPDATA%\QQEX
# FARM_QQ_MINIAPP_SRC_ROOT=
FARM_QQ_HOST_WS_URL=ws://127.0.0.1:8787/miniapp
FARM_QQ_HOST_VERSION=qq-host-1
# FARM_QQ_BUNDLE_OUT=D:\\nodejs_code\\农场相关\\农场使用cdp控制\\dist\\qq-miniapp-bootstrap.js

# CDP settings (used only on cdp / auto when CDP is selected)
FARM_CDP_WS=ws://127.0.0.1:62000
FARM_GATEWAY_USE_WMPF_BRIDGE=1
FARM_PING_CONTEXT_WAIT_MS=8000
